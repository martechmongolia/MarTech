# Playwright E2E environment. Copy to .env.e2e and fill in values from the
# Supabase project you want the suite to run against (recommended: a dedicated
# test project, NOT production).

E2E_SUPABASE_URL=https://your-ref.supabase.co
E2E_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Where the dev server is reachable. Default matches `npm run dev`
# (next dev --experimental-https on port 3000).
E2E_BASE_URL=https://localhost:3000

# Must equal E2E_BASE_URL so the passkey RP ID matches the origin the browser
# is actually visiting. The server reads this at request time via
# src/modules/auth/passkey-config.ts.
NEXT_PUBLIC_APP_URL=https://localhost:3000

# Required at runtime by the Next.js server the E2E suite spawns. These can
# point at the same values as E2E_SUPABASE_*.
NEXT_PUBLIC_SUPABASE_URL=https://your-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
