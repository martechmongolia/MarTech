# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile CAPTCHA — bot protection on /login
# https://dash.cloudflare.com/?to=/:account/turnstile
# Unset in dev → falls back to Cloudflare test keys (always pass).
# In production both MUST be set; server refuses to verify otherwise.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Meta (Facebook integration)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/meta/callback
META_API_VERSION=v21.0
META_TOKEN_ENCRYPTION_KEY=

# QPay V2 — https://merchant.qpay.mn
# Webhook auth uses per-invoice random tokens (not a global secret).
QPAY_BASE_URL=https://merchant.qpay.mn
QPAY_CLIENT_ID=
QPAY_CLIENT_SECRET=
QPAY_INVOICE_CODE=

# Comma-separated emails: bootstrap (empty system_admins), legacy /internal/ops, env operator mutations.
# /admin uses system_admins; see docs/admin-auth-v1.md
MARTECH_INTERNAL_OPS_EMAILS=

# AI (OpenAI)
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# Facebook Comment AI
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
FACEBOOK_WEBHOOK_VERIFY_TOKEN=your_random_token_here

# Vercel Cron secret — protects /api/cron/* and /api/digest/* endpoints.
# Vercel Cron sends this as the `x-cron-secret` header (or bearer in digest).
# Set to a random 32+ char token in Vercel Dashboard → Environment Variables.
CRON_SECRET=
